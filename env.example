# mmwave_vis local configuration
# Copy this file to .env and fill in your values:
#   cp env.example .env

# MQTT broker settings
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Zigbee2MQTT base topic
MQTT_BASE_TOPIC=zigbee2mqtt

# Zigbee stack: "z2m" or "zha"
ZIGBEE_STACK=z2m

# Debug logging (true/false)
DEBUG=false

# Home Assistant settings (only needed for ZHA stack)
HA_URL=http://localhost:8123
HA_TOKEN=

# Web UI port
PORT=5000
